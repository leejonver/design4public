# ============================================================
# D4P-CMS 환경변수 양식
# 이 파일을 복사해 `.env.local` 로 만들고 값을 채운다.
#   cp .env.example .env.local
# `.env.local` 은 git에 커밋하지 않는다.
# ============================================================

# --- Supabase (앱 런타임: Auth / PostgREST / Storage) ---
# Supabase 대시보드 > Project Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon public key (eyJ... 로 시작)>
SUPABASE_SERVICE_ROLE_KEY=<service_role secret key (eyJ... 로 시작, 서버 전용·노출 금지)>

# --- 앱 설정 ---
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_UPLOAD_URL=/api/upload
NEXT_PUBLIC_ENV=development

# --- DB 마이그레이션 적용용 (마이그레이션/검증 시에만 필요, 런타임 미사용) ---
# Supabase 대시보드 > Project Settings > Database > Connection string > "Transaction pooler"
# (URI 형식, 포트 6543). [YOUR-PASSWORD] 자리에 DB 비밀번호를 넣는다.
# 예: postgres://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://postgres.<project-ref>:<DB-PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres
